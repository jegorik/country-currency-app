# Example environment variables file
# Copy this to .env and fill in your values

# Databricks Configuration
DATABRICKS_HOST="https://your-databricks-instance.cloud.databricks.com"
DATABRICKS_TOKEN="dapi123456789abcdef123456789abcdef"
DATABRICKS_WAREHOUSE_ID="your_warehouse_id" 

# Project Configuration
ENVIRONMENT="dev"  # Options: dev, test, prod
PROJECT_NAME="Country Currency App"
OWNER="data_engineering"

# Terraform Backend Configuration
TF_VAR_backend_storage_account="your_storage_account"
TF_VAR_backend_container="terraform-state"
TF_VAR_backend_key="country-currency-app/terraform.tfstate"
TF_VAR_backend_access_key="your_access_key"

# Optional: CI/CD Configuration
GITHUB_TOKEN="your_github_token"
